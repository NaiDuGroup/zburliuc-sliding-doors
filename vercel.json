{
  "version": 2,
  "buildCommand": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true npx nx build web --configuration=production --skip-nx-cache",
  "installCommand": "npm install --include=dev",
  "outputDirectory": "dist/apps/web",
  "framework": null,
  "functions": {
    "server/server.mjs": {
      "runtime": "@vercel/node@3.0.0",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/robots\\.txt",
      "dest": "/browser/robots.txt"
    },
    {
      "src": "/(.*\\.(js|mjs|css|ico|png|jpg|jpeg|svg|webp|woff|woff2|ttf|eot|map)$)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "dest": "/browser/$1"
    },
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=86400" },
      "dest": "/browser/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server/server.mjs"
    }
  ]
}

{
  "version": 2,
  "buildCommand": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true npx nx build web --configuration=production --skip-nx-cache",
  "installCommand": "npm install --include=dev",
  "outputDirectory": "dist/apps/web/browser",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
